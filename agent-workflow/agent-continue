#!/bin/bash
# Resume an agent with feedback
# Usage: agent-continue <agent-name> "feedback message"

AGENT_NAME=$1
PROMPT=${2:-"Review feedback received. Check your status and feedback files."}

if [ -z "$AGENT_NAME" ]; then
    echo "Usage: agent-continue <agent-name> [prompt]"
    exit 1
fi

# Normalize agent name (remove agent: prefix if present)
AGENT_NAME=${AGENT_NAME#agent:}

# Validate we're in a workspace
if [ ! -f ".git/agent-workspace" ]; then
    echo "Error: Not in an agent workspace (missing .git/agent-workspace marker)"
    exit 1
fi

# Find agent info from agent-windows file
# Format: window\tdir\tbranch\tworkspace\tsession\tdata_dir
AGENT_DIR=""
AGENT_DATA_DIR=""
AGENT_WINDOW=""
AGENT_SESSION=""
if [ -f ".git/agent-windows" ]; then
    while IFS=$'\t' read -r window dir branch workspace session data_dir; do
        window_name=${window#agent:}
        if [ "$window_name" = "$AGENT_NAME" ]; then
            AGENT_DIR="$dir"
            AGENT_DATA_DIR="$data_dir"
            AGENT_WINDOW="$window"
            AGENT_SESSION="$session"
            break
        fi
    done < ".git/agent-windows"
fi

if [ -z "$AGENT_DIR" ]; then
    echo "Error: Agent '$AGENT_NAME' not found"
    echo "Available agents:"
    agent-list 2>/dev/null || cat .git/agent-windows 2>/dev/null | cut -f1
    exit 1
fi

if [ ! -d "$AGENT_DIR" ]; then
    echo "Error: Agent directory not found: $AGENT_DIR"
    exit 1
fi

# Load allowed tools
AGENT_CONFIG_DIR="$(dirname "$(readlink -f "$0")")"
ALLOWED_TOOLS_FILE="$AGENT_CONFIG_DIR/agent-allowed-tools"
if [ -f "$ALLOWED_TOOLS_FILE" ]; then
    ALLOWED_TOOLS=$(grep -v '^#' "$ALLOWED_TOOLS_FILE" | grep -v '^$' | tr '\n' ' ')
else
    ALLOWED_TOOLS="Edit Read Write Glob Grep Bash(git:*)"
fi

# Capture git appraise comments from agent's directory
APPRAISE_OUTPUT=$(cd "$AGENT_DIR" && git appraise show 2>/dev/null || echo "")

# Only include appraise comments if they've changed since last time
APPRAISE_NEW=""
if [ -n "$APPRAISE_OUTPUT" ]; then
    LAST_SEEN="$AGENT_DATA_DIR/appraise-last-seen.txt"
    if [ -f "$LAST_SEEN" ]; then
        # Compare to last seen - only include if different
        if ! diff -q <(echo "$APPRAISE_OUTPUT") "$LAST_SEEN" >/dev/null 2>&1; then
            APPRAISE_NEW="$APPRAISE_OUTPUT"
        fi
    else
        # First time seeing comments
        APPRAISE_NEW="$APPRAISE_OUTPUT"
    fi
    # Save current state for next comparison
    echo "$APPRAISE_OUTPUT" > "$LAST_SEEN"
fi

# Read feedback.md if it exists
FEEDBACK=""
if [ -f "$AGENT_DATA_DIR/feedback.md" ]; then
    FEEDBACK=$(cat "$AGENT_DATA_DIR/feedback.md")
fi

# Build the full prompt with all context
{
    echo "$PROMPT"
    echo ""
    if [ -n "$FEEDBACK" ]; then
        echo "=== REVIEWER FEEDBACK ==="
        echo "$FEEDBACK"
        echo ""
    fi
    if [ -n "$APPRAISE_NEW" ]; then
        echo "=== CODE REVIEW COMMENTS (git appraise) ==="
        echo "$APPRAISE_NEW"
        echo ""
    fi
    echo "Address the feedback above, then run submit-review when ready."
} > "$AGENT_DATA_DIR/continue-prompt"

# Update status
echo "working" > "$AGENT_DATA_DIR/status"

# Create launcher script (avoids tmux send-keys escaping issues)
cat > "$AGENT_DATA_DIR/continue.sh" << LAUNCHER
#!/bin/bash
cd "$AGENT_DIR"

# Export env vars for path validation hook
export AGENT_ALLOWED_DIR="$AGENT_DIR"
export AGENT_DATA_DIR="$AGENT_DATA_DIR"

exec claude --continue --permission-mode acceptEdits \\
    --allowedTools '$ALLOWED_TOOLS' \\
    --append-system-prompt "\$(cat $AGENT_DATA_DIR/system-prompt 2>/dev/null)" \\
    "\$(cat $AGENT_DATA_DIR/continue-prompt)"
LAUNCHER
chmod +x "$AGENT_DATA_DIR/continue.sh"

# Send to agent's tmux window
TMUX_TARGET="$AGENT_SESSION:$AGENT_WINDOW"
tmux send-keys -t "$TMUX_TARGET" "$AGENT_DATA_DIR/continue.sh" Enter

echo "Resumed agent '$AGENT_NAME' in tmux window '$AGENT_WINDOW'"
