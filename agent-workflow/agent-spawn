#!/bin/bash
set -e

# Get the directory where this script lives (for finding config files)
AGENT_CONFIG_DIR="$(dirname "$(readlink -f "$0")")"

TASK="$1"
AGENT_NAME="${2:-}"
REPO_PATH="${3:-}"

if [ -z "$TASK" ]; then
    echo "Usage: agent-spawn <task-description> [agent-name] [repo-path]"
    echo "  agent-name: short name for branch/tab (prompted if not provided)"
    echo "  repo-path: optional path to repo (default: current directory)"
    exit 1
fi

# Generate agent name if not provided
if [ -z "$AGENT_NAME" ]; then
    echo "Task: $TASK"
    echo "Generating agent name..."
    AGENT_NAME=$(echo "Generate a short (1-3 word) kebab-case name for an agent working on this task. Reply with ONLY the name, nothing else: $TASK" | claude --print 2>/dev/null | tr -d '[:space:]')
    if [ -z "$AGENT_NAME" ]; then
        # Fallback to prompting if claude fails
        read -p "Short name for this agent (branch/tab): " AGENT_NAME
        if [ -z "$AGENT_NAME" ]; then
            echo "Error: Agent name is required"
            exit 1
        fi
    else
        echo "Agent name: $AGENT_NAME"
    fi
fi

# Sanitize agent name (alphanumeric and hyphens only)
AGENT_NAME=$(echo "$AGENT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//')

# Validate we're in a workspace
WORKSPACE_MAIN=$(pwd)
if [ ! -f ".git/agent-workspace" ]; then
    echo "Error: Not in an agent workspace (missing .git/agent-workspace marker)"
    echo "Run 'agent-workspace <feature-name>' first"
    exit 1
fi

FEATURE=$(cat .git/agent-workspace)
FEATURE_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Determine workspace root (parent of main/)
WORKSPACE_ROOT=$(dirname "$WORKSPACE_MAIN")

# Create agent branch
BRANCH="agent/$AGENT_NAME"

# Create agent directory as a git worktree in the workspace
AGENT_DIR="$WORKSPACE_ROOT/$AGENT_NAME"

if [ -d "$AGENT_DIR" ]; then
    echo "Error: Agent directory already exists: $AGENT_DIR"
    echo "Use 'agent-cleanup $AGENT_NAME' first or choose a different name"
    exit 1
fi

# Create worktree with new branch
git worktree add -b "$BRANCH" "$AGENT_DIR" "$FEATURE_BRANCH"
cd "$AGENT_DIR"

# Initialize submodules if any
git submodule update --init --recursive 2>/dev/null || true

# Hook settings are inherited from $WORKSPACE_ROOT/.claude/settings.json
# (created by agent-workspace) - no per-agent settings needed

# Exclude .claude/ from git so agents don't commit it (worktree-aware)
AGENT_GIT_DIR=$(git -C "$AGENT_DIR" rev-parse --git-dir)
mkdir -p "$AGENT_GIT_DIR/info"
echo ".claude/" >> "$AGENT_GIT_DIR/info/exclude"

# Configure git for this agent (use 'local' remote for PRs against workspace)
git config --add remote.local.fetch '+refs/notes/*:refs/notes/*'
git config appraise.target "$FEATURE_BRANCH"

# Create agent data directory in workspace (not in agent's git checkout)
AGENT_DATA_DIR="$WORKSPACE_MAIN/.git/agent-data/$AGENT_NAME"
mkdir -p "$AGENT_DATA_DIR"

# Initialize status file
echo "working" > "$AGENT_DATA_DIR/status"

# Store the task description (avoids tmux send-keys truncation)
printf '%s' "$TASK" > "$AGENT_DATA_DIR/task"

# Store agent system prompt for --append-system-prompt (and --continue)
cat > "$AGENT_DATA_DIR/system-prompt" << AGENT_INSTRUCTIONS
You are working in an isolated worktree. Your changes will be reviewed before merging.

YOUR WORKSPACE: $AGENT_DIR
FORBIDDEN DIRECTORY: $WORKSPACE_MAIN (the coordinator's workspace)

WORKFLOW:
1. Complete your task
2. Run: submit-review "Description of changes"
3. Exit with /exit - you will be restarted when feedback arrives

If you are resumed with feedback, address the requested changes, then submit-review again.

FEEDBACK FILES (when resumed):
   cat $AGENT_DATA_DIR/feedback.md   # Human feedback
   git appraise show                  # Detailed code comments

RULES:
- NEVER read, write, or modify files in $WORKSPACE_MAIN - that is the coordinator's directory
- ONLY work within your worktree: $AGENT_DIR
- Do not use .. paths to navigate outside your worktree
- Use submit-review for all submissions
- Exit with /exit after each submit-review
- Never push to main or upstream directly
AGENT_INSTRUCTIONS

# Open new tmux window
WINDOW_NAME="agent:$AGENT_NAME"
SESSION=$(tmux display-message -p '#S')
tmux new-window -n "$WINDOW_NAME" -c "$AGENT_DIR"

# Wait for window to be ready
sleep 0.5

# Store agent info for later communication (tab-delimited to avoid path issues)
printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$WINDOW_NAME" "$AGENT_DIR" "$BRANCH" "$WORKSPACE_MAIN" "$SESSION" "$AGENT_DATA_DIR" >> $WORKSPACE_MAIN/.git/agent-windows

# Load allowed tools from config file
ALLOWED_TOOLS_FILE="$AGENT_CONFIG_DIR/agent-allowed-tools"
if [ -f "$ALLOWED_TOOLS_FILE" ]; then
    # Read config, strip comments and blank lines, join into space-separated string
    ALLOWED_TOOLS=$(grep -v '^#' "$ALLOWED_TOOLS_FILE" | grep -v '^$' | tr '\n' ' ')
else
    # Fallback defaults
    ALLOWED_TOOLS="Edit Read Write Glob Grep Bash(git:*)"
fi

# Create launcher script (avoids tmux send-keys truncation with long tasks)
cat > "$AGENT_DATA_DIR/launch.sh" << LAUNCHER
#!/bin/bash
cd "$AGENT_DIR"

# Export env vars for path validation hook
export AGENT_ALLOWED_DIR="$AGENT_DIR"
export AGENT_DATA_DIR="$AGENT_DATA_DIR"

exec claude --permission-mode acceptEdits \\
    --allowedTools '$ALLOWED_TOOLS' \\
    --append-system-prompt "\$(cat $AGENT_DATA_DIR/system-prompt)" \\
    "\$(cat $AGENT_DATA_DIR/task)"
LAUNCHER
chmod +x "$AGENT_DATA_DIR/launch.sh"

# Start agent via launcher script
tmux send-keys -t "$SESSION:$WINDOW_NAME" "$AGENT_DATA_DIR/launch.sh" Enter

echo "Spawned agent in $AGENT_DIR"
echo "Worktree of: $WORKSPACE_MAIN"
echo "tmux window: $WINDOW_NAME"
